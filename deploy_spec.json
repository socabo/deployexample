{
  "spec": {
    "name": "flask-docker-demo",
    "region": "nyc",
    "services": [
      {
        "name": "web",
        "dockerfile_path": "Dockerfile",
        "source_dir": "/",
        "http_port": 5000,
        "instance_count": 1,
        "instance_size_slug": "basic-xxs",
        "envs": [
          {
            "key": "ENVIRONMENT",
